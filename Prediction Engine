class LicenseOracleGate:
    """许可证神谕检查"""
    
    REJECTION_CODES = {
        "NO_EVIDENCE": "缺乏可验证证据",
        "ETHICAL_VIOLATION": "违反伦理准则",
        "LOGICAL_CONTRADICTION": "逻辑矛盾",
        "TEMPORAL_PARADOX": "时间悖论",
        "UNCERTAINTY_TOO_HIGH": "不确定性过高"
    }
    
    def validate(self, prediction: Dict) -> Dict:
        """执行许可证检查"""
        checks = [
            self._has_verifiable_evidence(prediction),
            self._passes_ethical_review(prediction),
            self._is_logically_consistent(prediction),
            self._is_temporally_plausible(prediction),
            self._has_reasonable_confidence(prediction)
        ]
        
        if all(checks):
            return {"status": "APPROVED", "prediction": prediction}
        else:
            failure_reason = self._identify_failure(checks)
            return {
                "status": "REJECTED",
                "reason": self.REJECTION_CODES.get(failure_reason, "未知原因"),
                "suggestion": self._generate_suggestion(failure_reason),
                "appeal_process": "可通过社区投票上诉此决定"
            }
    
    def _has_verifiable_evidence(self, prediction: Dict) -> bool:
        """检查是否有可验证证据"""
        evidence = prediction.get("supporting_evidence", [])
        return len(evidence) > 0
    
    def _passes_ethical_review(self, prediction: Dict) -> bool:
        """通过伦理审查"""
        # 检查伦理标记
        ethical_flags = prediction.get("ethical_flags", [])
        prohibited = ["violence_prediction", "market_manipulation"]
        return not any(flag in prohibited for flag in ethical_flags)
    
    def _is_logically_consistent(self, prediction: Dict) -> bool:
        """逻辑一致性检查"""
        # 简化检查
        reasoning = prediction.get("reasoning_summary", "")
        return "矛盾" not in reasoning and "冲突" not in reasoning
    
    def _is_temporally_plausible(self, prediction: Dict) -> bool:
        """时间合理性检查"""
        # 检查时间一致性
        expiration = prediction.get("expiration")
        if expiration:
            import datetime
            exp_date = datetime.datetime.fromisoformat(expiration.replace('Z', '+00:00'))
            now = datetime.datetime.now(datetime.timezone.utc)
            return exp_date > now
        return True
    
    def _has_reasonable_confidence(self, prediction: Dict) -> bool:
        """合理置信度检查"""
        confidence = prediction.get("confidence_score", 0)
        return 0.3 <= confidence <= 0.9
    
    def _identify_failure(self, checks: List[bool]) -> str:
        """识别失败原因"""
        failure_reasons = [
            "NO_EVIDENCE",
            "ETHICAL_VIOLATION", 
            "LOGICAL_CONTRADICTION",
            "TEMPORAL_PARADOX",
            "UNCERTAINTY_TOO_HIGH"
        ]
        
        for i, check in enumerate(checks):
            if not check and i < len(failure_reasons):
                return failure_reasons[i]
        return "UNKNOWN"
    
    def _generate_suggestion(self, failure_reason: str) -> str:
        """生成建议"""
        suggestions = {
            "NO_EVIDENCE": "请提供可验证的证据来源",
            "ETHICAL_VIOLATION": "请修改问题以避免违反伦理准则",
            "LOGICAL_CONTRADICTION": "请确保预测逻辑一致",
            "TEMPORAL_PARADOX": "请检查时间范围是否合理",
            "UNCERTAINTY_TOO_HIGH": "请提供更具体的问题或更多背景信息"
        }
        return suggestions.get(failure_reason, "请修改问题后重新提交")


